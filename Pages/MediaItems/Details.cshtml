@page "{id:int?}"
@model MediaApp.Pages.MediaItems.DetailsModel

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>MediaItem</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.MediaItem.Title)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.MediaItem.Title)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.MediaItem.Type)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.MediaItem.Type)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.MediaItem.IsCompleted)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.MediaItem.IsCompleted)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.MediaItem.Information)
        </dt>
        <dd class="col-sm-10">
            @if (!string.IsNullOrEmpty(Model.MediaItem.Information) && Model.MediaItem.Information.StartsWith("http"))
            {
                <a href="@Model.MediaItem.Information" target="_blank">@Model.MediaItem.Information</a>
            }
            else
            {
                @Model.MediaItem.Information
            }
        </dd>
    </dl>
</div>
<div>
    <a asp-page="./Edit" asp-route-id="@Model.MediaItem.Id">Edit</a> |
    <a asp-page="./Index">Back to List</a>
</div>
