@page "{id:int?}"
@model MediaApp.Pages.MediaItems.EditModel

@using MediaApp.Models

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>MediaItem</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="MediaItem.Id" />
            <div class="form-group">
<span class="text-danger">*</span>
                <label asp-for="MediaItem.Title" class="control-label"></label>
                <input asp-for="MediaItem.Title" class="form-control" aria-required="true"/>
                <span asp-validation-for="MediaItem.Title" class="text-danger"></span>
            </div>
            <div class="form-group">
<span class="text-danger">*</span>
                <label asp-for="MediaItem.Type" class="control-label"></label>
                <select asp-for="MediaItem.Type"
                        class="form-control"
                        asp-items="Html.GetEnumSelectList<MediaType>()">
                    <option value="">-- Select Type --</option>
                </select>
                <span asp-validation-for="MediaItem.Type" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="MediaItem.IsCompleted" /> @Html.DisplayNameFor(model => model.MediaItem.IsCompleted)
                </label>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
